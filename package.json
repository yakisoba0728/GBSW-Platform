{
  "name": "gbsw-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "pnpm --filter @gbsw/api build && pnpm --filter @gbsw/web build",
    "lint": "pnpm --filter @gbsw/api lint && pnpm --filter @gbsw/web lint",
    "test": "pnpm --filter @gbsw/api test && pnpm --filter @gbsw/web test",
    "db:up": "docker compose up -d db pgadmin",
    "db:down": "docker compose down",
    "db:prepare": "node scripts/prepare-db.mjs",
    "db:migrate": "pnpm --filter @gbsw/api exec prisma migrate deploy --schema prisma/schema.prisma",
    "deploy:production": "node scripts/deploy-production.mjs"
  },
  "pnpm": {
    "overrides": {
      "effect": "3.20.0",
      "path-to-regexp": "8.4.0"
    }
  },
  "devDependencies": {
    "dotenv": "^17.3.1"
  }
}
