POSTGRES_USER=gbsw
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=gbsw_platform

WEB_PORT=3000
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-this-pgadmin-password

# Public direct Nest API origin. Do not point this to the Next.js /api routes.
# API_INTERNAL_URL is injected by docker-compose.production.yml as http://api:3001.
NEXT_PUBLIC_API_URL=https://api.example.com

SUPER_ADMIN_ID=change-this-super-admin-id
SUPER_ADMIN_PASSWORD=change-this-super-admin-password
INTERNAL_API_SECRET=change-this-long-random-internal-api-secret
