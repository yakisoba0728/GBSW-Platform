POSTGRES_USER=gbsw
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=gbsw_platform

WEB_PORT=3000
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-this-pgadmin-password

NEXT_PUBLIC_API_URL=https://example.com/api

# SUPER_ADMIN_* is consumed by the API only and is optional after the first
# successful credential bootstrap.
SUPER_ADMIN_ID=change-this-super-admin-id
SUPER_ADMIN_PASSWORD_HASH=replace-with-hashpassword-output
INTERNAL_API_SECRET=change-this-long-random-internal-api-secret
