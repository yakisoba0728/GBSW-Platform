generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum School {
  GBSW
  BYMS
}

enum SchoolMileageType {
  REWARD
  PENALTY
}

enum DormMileageType {
  REWARD
  PENALTY
}

enum AuthRole {
  SUPER_ADMIN
  STUDENT
  TEACHER
}

model Student {
  studentId            String               @id @map("student_id")
  school               School
  currentYear          Int                  @map("current_year")
  currentClass         Int                  @map("current_class_number")
  currentNumber        Int                  @map("current_student_number")
  majorSubject         String?              @map("major_subject")
  name                 String
  phone                String
  passwordHash         String               @map("password_hash")
  mustChangePassword   Boolean              @default(true) @map("must_change_password")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  schoolMileageEntries SchoolMileageEntry[]
  dormMileageEntries   DormMileageEntry[]

  @@map("students")
}

model Teacher {
  teacherId                   String               @id @map("teacher_id")
  name                        String
  phone                       String
  passwordHash                String               @map("password_hash")
  mustChangePassword          Boolean              @default(true) @map("must_change_password")
  isDormTeacher               Boolean              @default(false) @map("is_dorm_teacher")
  createdAt                   DateTime             @default(now()) @map("created_at")
  updatedAt                   DateTime             @updatedAt @map("updated_at")
  createdSchoolMileageEntries SchoolMileageEntry[] @relation("SchoolMileageCreatedBy")
  updatedSchoolMileageEntries SchoolMileageEntry[] @relation("SchoolMileageUpdatedBy")
  deletedSchoolMileageEntries SchoolMileageEntry[] @relation("SchoolMileageDeletedBy")
  dormMileageEntries          DormMileageEntry[]   @relation("DormEntryCreatedBy")
  dormMileageEntriesUpdated   DormMileageEntry[]   @relation("DormEntryUpdatedBy")
  dormMileageEntriesDeleted   DormMileageEntry[]   @relation("DormEntryDeletedBy")

  @@map("teachers")
}

model SchoolMileageRule {
  id           Int                  @id @default(autoincrement())
  type         SchoolMileageType
  category     String
  name         String
  defaultScore Int                  @map("default_score")
  displayOrder Int                  @map("display_order")
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  entries      SchoolMileageEntry[]

  @@unique([type, category, name])
  @@index([isActive, displayOrder])
  @@map("school_mileage_rules")
}

model SchoolMileageEntry {
  id                 Int               @id @default(autoincrement())
  studentId          String            @map("student_id")
  ruleId             Int               @map("rule_id")
  type               SchoolMileageType
  score              Int
  reason             String?
  awardedAt          DateTime          @map("awarded_at")
  createdByTeacherId String            @map("created_by_teacher_id")
  updatedByTeacherId String?           @map("updated_by_teacher_id")
  deletedByTeacherId String?           @map("deleted_by_teacher_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")
  student            Student           @relation(fields: [studentId], references: [studentId])
  rule               SchoolMileageRule @relation(fields: [ruleId], references: [id])
  createdByTeacher   Teacher           @relation("SchoolMileageCreatedBy", fields: [createdByTeacherId], references: [teacherId])
  updatedByTeacher   Teacher?          @relation("SchoolMileageUpdatedBy", fields: [updatedByTeacherId], references: [teacherId])
  deletedByTeacher   Teacher?          @relation("SchoolMileageDeletedBy", fields: [deletedByTeacherId], references: [teacherId])

  @@index([studentId, deletedAt, awardedAt])
  @@index([type, deletedAt, awardedAt])
  @@index([deletedAt, awardedAt])
  @@map("school_mileage_entries")
}

model AuthSession {
  id                 String   @id @default(cuid())
  accountId          String   @map("account_id")
  role               AuthRole
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  expiresAt          DateTime @map("expires_at")
  revokedAt          DateTime? @map("revoked_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([accountId, role, revokedAt, expiresAt])
  @@index([expiresAt, revokedAt])
  @@map("auth_sessions")
}

model LoginThrottle {
  key             String    @id
  failedCount     Int       @default(0) @map("failed_count")
  windowStartedAt DateTime  @map("window_started_at")
  lockedUntil     DateTime? @map("locked_until")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("login_throttles")
}

model DormMileageRule {
  id           Int             @id @default(autoincrement())
  type         DormMileageType
  category     String
  name         String
  defaultScore Int             @map("default_score")
  minScore     Int?            @map("min_score")
  maxScore     Int?            @map("max_score")
  displayOrder Int             @map("display_order")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  entries DormMileageEntry[]

  @@unique([type, category, name])
  @@index([isActive, displayOrder])
  @@map("dorm_mileage_rules")
}

model DormMileageEntry {
  id                 Int             @id @default(autoincrement())
  studentId          String          @map("student_id")
  ruleId             Int             @map("rule_id")
  type               DormMileageType
  score              Int
  reason             String?
  awardedAt          DateTime        @map("awarded_at")
  createdByTeacherId String          @map("created_by_teacher_id")
  updatedByTeacherId String?         @map("updated_by_teacher_id")
  deletedByTeacherId String?         @map("deleted_by_teacher_id")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  deletedAt          DateTime?       @map("deleted_at")

  student          Student         @relation(fields: [studentId], references: [studentId])
  rule             DormMileageRule @relation(fields: [ruleId], references: [id])
  createdByTeacher Teacher         @relation("DormEntryCreatedBy", fields: [createdByTeacherId], references: [teacherId])
  updatedByTeacher Teacher?        @relation("DormEntryUpdatedBy", fields: [updatedByTeacherId], references: [teacherId])
  deletedByTeacher Teacher?        @relation("DormEntryDeletedBy", fields: [deletedByTeacherId], references: [teacherId])

  @@index([studentId, deletedAt, awardedAt])
  @@index([type, deletedAt, awardedAt])
  @@index([deletedAt, awardedAt])
  @@map("dorm_mileage_entries")
}
